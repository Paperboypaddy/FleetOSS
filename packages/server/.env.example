# ── Server ──
PORT=4000
HOST=0.0.0.0
BASE_URL=http://localhost:4000

# ── Database ──
DATABASE_URL=postgres://fleetoss:fleetoss_dev@localhost:5432/fleetoss

# ── JWT ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=

# ── Storage (S3-compatible) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=fleetoss
S3_SECRET_KEY=fleetoss_dev
S3_BUCKET=fleetoss

# ── Redis (optional) ──
REDIS_URL=redis://localhost:6379

# ── Auth Providers ──

# LDAP / Active Directory
# AUTH_LDAP_ENABLED=true
# AUTH_LDAP_URL=ldap://localhost:389
# AUTH_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# AUTH_LDAP_BIND_PASSWORD=admin
# AUTH_LDAP_SEARCH_BASE=dc=example,dc=com
# AUTH_LDAP_SEARCH_FILTER=(mail={{email}})
# AUTH_LDAP_USER_DN_TEMPLATE=  # Alternative to search: cn={{email}},ou=users,dc=example,dc=com
# AUTH_LDAP_NAME_ATTRIBUTE=cn
# AUTH_LDAP_DEFAULT_ROLE=viewer

# OpenID Connect (Keycloak, Google, Azure AD, Okta, etc.)
# AUTH_OIDC_ENABLED=true
# AUTH_OIDC_ISSUER=http://localhost:8080/realms/fleetoss
# AUTH_OIDC_CLIENT_ID=fleetoss-oidc
# AUTH_OIDC_CLIENT_SECRET=fleetoss-oidc-client-secret
# AUTH_OIDC_REDIRECT_URI=http://localhost:4000/api/auth/oidc/callback
# AUTH_OIDC_SCOPE=openid profile email
# AUTH_OIDC_NAME_CLAIM=name
# AUTH_OIDC_DEFAULT_ROLE=viewer

# OAuth2 (GitHub, GitLab, etc.)
# AUTH_OAUTH2_ENABLED=true
# AUTH_OAUTH2_AUTHORIZE_URL=https://github.com/login/oauth/authorize
# AUTH_OAUTH2_TOKEN_URL=https://github.com/login/oauth/access_token
# AUTH_OAUTH2_USERINFO_URL=https://api.github.com/user
# AUTH_OAUTH2_CLIENT_ID=your-client-id
# AUTH_OAUTH2_CLIENT_SECRET=your-client-secret
# AUTH_OAUTH2_REDIRECT_URI=http://localhost:4000/api/auth/oauth2/callback
# AUTH_OAUTH2_SCOPE=user:email
# AUTH_OAUTH2_EMAIL_FIELD=email
# AUTH_OAUTH2_NAME_FIELD=name
# AUTH_OAUTH2_DEFAULT_ROLE=viewer

# SAML 2.0 (Keycloak, Azure AD, Okta, etc.)
# AUTH_SAML_ENABLED=true
# AUTH_SAML_ENTRY_POINT=http://localhost:8080/realms/fleetoss/protocol/saml
# AUTH_SAML_ISSUER=fleetoss-saml
# AUTH_SAML_CERT=  # IdP signing certificate (base64 or PEM)
# AUTH_SAML_PRIVATE_KEY=  # SP private key (base64 or PEM, optional)
# AUTH_SAML_CALLBACK_URL=http://localhost:4000/api/auth/saml/callback
# AUTH_SAML_NAME_ATTRIBUTE=cn
# AUTH_SAML_EMAIL_ATTRIBUTE=mail
# AUTH_SAML_DEFAULT_ROLE=viewer
