{
  "name": "fleetoss",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/server",
    "build": "npm run build -w packages/core && npm run build -w packages/server",
    "db:migrate": "npm run db:migrate -w packages/server",
    "lint": "tsc --noEmit -p packages/server/tsconfig.json",
    "test": "npm run test -w packages/server && cd app && npx vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "ldapjs": "^3.0.7",
    "openid-client": "^6.8.4",
    "samlify": "^2.13.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "vitest": "^4.1.9"
  }
}
